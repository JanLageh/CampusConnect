rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to validate user document structure during creation
    function isValidUserCreation() {
      let requiredFields = ['fullName', 'email', 'studentId', 'role', 'groupMemberships', 'createdAt', 'updatedAt'];
      let hasAllFields = request.resource.data.keys().hasAll(requiredFields);
      let validRole = request.resource.data.role == 'student';
      let validGroupMemberships = request.resource.data.groupMemberships is list;
      let userIdMatches = request.auth.uid == resource.id;
      
      return hasAllFields && validRole && validGroupMemberships && userIdMatches;
    }
    
    // Helper function to validate user document updates
    function isValidUserUpdate() {
      // Only allow updates to specific fields
      let allowedFields = ['fullName', 'studentId', 'groupMemberships', 'updatedAt'];
      let onlyAllowedFields = request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
      
      // Prevent modification of critical fields
      let emailUnchanged = request.resource.data.email == resource.data.email;
      let roleUnchanged = request.resource.data.role == resource.data.role;
      let createdAtUnchanged = request.resource.data.createdAt == resource.data.createdAt;
      
      return onlyAllowedFields && emailUnchanged && roleUnchanged && createdAtUnchanged;
    }
    
    // Users collection rules
    match /users/{userId} {
      // Allow read access only to the user's own document
      // Requirement 7.5: Enforce read access only for the authenticated user's own document
      allow read: if isOwner(userId);
      
      // Allow user creation during registration
      // Requirement 10.3: Prevent unauthorized access to user documents
      // Users can only create their own document with valid structure
      allow create: if isOwner(userId) && isValidUserCreation();
      
      // Allow updates only to the user's own document with restricted fields
      // Requirement 10.3: Prevent unauthorized updates
      allow update: if isOwner(userId) && isValidUserUpdate();
      
      // Prevent deletion of user documents
      allow delete: if false;
    }
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if user has admin or moderator role
    function isAdminOrModerator() {
      let userData = getUserData();
      return isAuthenticated() && (userData.role == 'admin' || userData.role == 'moderator');
    }
    
    // Helper function to check if user can read announcement based on targetAudience
    function canReadAnnouncement(announcement) {
      let userData = getUserData();
      let userRole = userData.role;
      let userGroups = userData.get('groupMemberships', []);
      
      // Check if user's role is in targetAudience
      let roleMatches = announcement.targetAudience.hasAny([userRole]);
      
      // Check if any of user's groups are in targetAudience
      let groupMatches = announcement.targetAudience.hasAny(userGroups);
      
      return roleMatches || groupMatches;
    }
    
    // Announcements collection rules
    match /announcements/{announcementId} {
      // Allow list queries for all authenticated users.
      // NOTE: This does NOT enforce targetAudience filtering at the rule level.
      // The client-side datasource applies the filter via .where('targetAudience', arrayContainsAny: ...).
      // Single-document reads (get) still enforce targetAudience via canReadAnnouncement().
      // Admins/moderators can list all; regular users must filter by targetAudience in their queries.
      allow list: if isAuthenticated();
      
      // Allow get (single document read) only if user's role or groups match targetAudience
      // or if user is admin/moderator
      allow get: if isAuthenticated() && 
                    (isAdminOrModerator() || canReadAnnouncement(resource.data));
      
      // Only admins and moderators can create announcements
      allow create: if isAdminOrModerator();
      
      // Only admins and moderators can update announcements
      allow update: if isAdminOrModerator();
      
      // Only admins and moderators can delete announcements
      allow delete: if isAdminOrModerator();
    }
    
    // Helper function to check if user is a member of the group chat
    function isChatMember(chatData) {
      return isAuthenticated() && request.auth.uid in chatData.memberIds;
    }
    
    // Helper function to check if user is the chat creator
    function isChatCreator(chatData) {
      return isAuthenticated() && request.auth.uid == chatData.creatorId;
    }
    
    // Helper function to validate group chat creation
    function isValidGroupChatCreation() {
      let requiredFields = ['name', 'memberIds', 'creatorId', 'isPublic', 'createdAt'];
      let hasAllFields = request.resource.data.keys().hasAll(requiredFields);
      let creatorMatches = request.auth.uid == request.resource.data.creatorId;
      let creatorInMembers = request.auth.uid in request.resource.data.memberIds;
      
      return hasAllFields && creatorMatches && creatorInMembers;
    }
    
    // Group chats collection rules
    match /groupChats/{chatId} {
      // Allow read access only if user is in memberIds
      allow read: if isChatMember(resource.data);
      
      // Allow creation if user is the creator and in memberIds
      allow create: if isValidGroupChatCreation();
      
      // Allow updates only if user is a member (for adding members, updating metadata)
      allow update: if isChatMember(resource.data);
      
      // Allow deletion only by the creator
      allow delete: if isChatCreator(resource.data);
      
      // Messages subcollection rules
      match /messages/{messageId} {
        // Helper function to check if user can moderate messages
        function canModerateMessage() {
          let chatData = get(/databases/$(database)/documents/groupChats/$(chatId)).data;
          let userData = getUserData();
          let isAdmin = userData.role == 'admin';
          let isCreatorWithRole = (request.auth.uid == chatData.creatorId) && 
                                  (userData.role == 'organization_leader' || userData.role == 'admin');
          return isAdmin || isCreatorWithRole;
        }
        
        // Helper function to validate message creation
        function isValidMessageCreation() {
          let requiredFields = ['senderId', 'senderName', 'content', 'isDeleted', 'createdAt'];
          let hasAllFields = request.resource.data.keys().hasAll(requiredFields);
          let senderMatches = request.auth.uid == request.resource.data.senderId;
          let notDeleted = request.resource.data.isDeleted == false;
          
          return hasAllFields && senderMatches && notDeleted;
        }
        
        // Allow read if user is a member of the parent chat
        allow read: if isChatMember(get(/databases/$(database)/documents/groupChats/$(chatId)).data);
        
        // Allow creation if user is a member and sender matches auth
        allow create: if isChatMember(get(/databases/$(database)/documents/groupChats/$(chatId)).data) && 
                         isValidMessageCreation();
        
        // Allow update only for soft-deletion by authorized moderators
        // Only isDeleted field can be changed, and only from false to true
        allow update: if canModerateMessage() && 
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted']) &&
                         resource.data.isDeleted == false &&
                         request.resource.data.isDeleted == true;
        
        // Prevent hard deletion
        allow delete: if false;
      }
    }
    
    // Categories collection rules
    match /categories/{categoryId} {
      // All authenticated users can read categories
      allow read: if isAuthenticated();
      
      // Only admins and moderators can create/update/delete categories
      allow create: if isAdminOrModerator();
      allow update: if isAdminOrModerator();
      allow delete: if isAdminOrModerator();
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
